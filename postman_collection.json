                  "type": "string"
                },
                {
                  "key": "in",
                  "value": "header",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/robots?status=active&location=5.1423&search=6G&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "robots"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "active",
